# Nova configuration — copy this to `.env` (which is gitignored) and fill in.

# Gemini API key (free tier, 1500 req/day): https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Model backend: "gemini" (default, cloud) or "local" (Ollama, fully offline).
NOVA_MODEL_BACKEND=gemini
NOVA_GEMINI_MODEL=gemini-2.5-flash

# Optional: point Nova at a TaskFlow data dir other than ~/.taskflow
# (used by CI, where the data is restored from a secret rather than a real install).
# TASKFLOW_DATA_PATH=/path/to/.taskflow
